generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())

  resumes       Resume[]
  tasks         Task[]
  notifications Notification[]
}

model Resume {
  id          String   @id @default(cuid())
  userId      String
  title       String
  contentJson String
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum MilestoneCategory {
  RESUME
  INTERNSHIP
  INTERVIEW
  GENERAL
}

model Task {
  id          String            @id @default(cuid())
  userId      String
  title       String
  description String?
  category    MilestoneCategory @default(GENERAL)
  dueDate     DateTime?
  completed   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum NotificationKind {
  REMINDER
  DEADLINE
  SYSTEM
  MILESTONE
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  message   String
  read      Boolean            @default(false)
  kind      NotificationKind   @default(REMINDER)
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
